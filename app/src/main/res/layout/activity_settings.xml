<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center|top"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Главные Настройки"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="24dp"
        android:textColor="#333333" />

    <Button
        android:id="@+id/btnLang"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Язык (В разработке)"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#9E9E9E"/>

    <Button
        android:id="@+id/btnTextures"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Текстуры фигур (В разработке)"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#9E9E9E"/>

    <Button
        android:id="@+id/btnBgColor"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Цвет фона (В разработке)"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#9E9E9E"/>

    <Switch
        android:id="@+id/swGlobalBlueTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Синяя тема доски (Мерзость)"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnBackToMenu"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Сохранить и Выйти" />

</LinearLayout>